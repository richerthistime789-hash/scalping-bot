"""
strategy.py — Asian Range Sweep with Scoring System
แต่ละ confirmation มี score รวมแล้ว >= threshold = entry
"""
from dataclasses import dataclass
from typing import Optional
from datetime import datetime
from zoneinfo import ZoneInfo

PIP_SIZE         = 0.01
MIN_RR           = 1.5
MIN_SL_PIPS      = 30
MAX_SL_PIPS      = 300
MIN_SWEEP_PIPS   = 30
MAX_SWEEP_PIPS   = 200
SWEEP_LOOKBACK   = 12

# ── Score thresholds ──
SCORE_HIGH       = 6   # เข้า full size
SCORE_MEDIUM     = 4   # เข้า half size
SCORE_MAX        = 8

UTC = ZoneInfo("UTC")


@dataclass
class AsianRange:
    detected: bool
    high: Optional[float]
    low: Optional[float]
    mid: Optional[float]
    size_pips: Optional[float]
    is_london_session: bool
    reason: str


@dataclass
class M5Signal:
    signal: str
    pattern: str
    entry: Optional[float]
    sl: Optional[float]
    tp: Optional[float]
    sl_pips: Optional[float]
    rr: Optional[float]
    is_with_trend: bool
    reason: str
    score: int = 0
    score_breakdown: str = ""


def _get_utc_hour(time_str):
    try:
        dt = datetime.fromisoformat(time_str)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=UTC)
        else:
            dt = dt.astimezone(UTC)
        return dt.hour, dt.date()
    except:
        return None, None


# ─── Asian Range ─────────────────────────────────────────────────────────────

def calc_asian_range(m15_candles):
    if not m15_candles:
        return AsianRange(False, None, None, None, None, False, "No candles")
    last = m15_candles[-1]
    last_hour, last_date = _get_utc_hour(last.get("time", ""))
    if last_hour is None:
        return AsianRange(False, None, None, None, None, False, "Time error")

    is_london = 7 <= last_hour < 21

    asian_candles = []
    for c in m15_candles:
        h, d = _get_utc_hour(c.get("time", ""))
        if h is None or d is None: continue
        if d == last_date and 0 <= h < 7:
            asian_candles.append(c)

    if len(asian_candles) < 4:
        return AsianRange(False, None, None, None, None, is_london,
                          f"Only {len(asian_candles)} Asian candles")

    asian_high = max(c.get("high", 0) for c in asian_candles)
    asian_low  = min(c.get("low",  0) for c in asian_candles if c.get("low", 0) > 0)
    size_pips = (asian_high - asian_low) / PIP_SIZE

    return AsianRange(True, round(asian_high, 2), round(asian_low, 2),
                      round((asian_high + asian_low) / 2, 2),
                      round(size_pips, 1), is_london,
                      f"Asian {asian_low:.2f}-{asian_high:.2f} ({size_pips:.0f}p)")


# ─── Reversal Pattern ────────────────────────────────────────────────────────

def _is_bullish_reversal(c1, c2):
    o2,c2v = c2.get("open",0), c2.get("close",0)
    h2,l2  = c2.get("high",0), c2.get("low",0)
    body2 = abs(c2v-o2); rng2 = h2-l2
    if rng2 < 0.05: return False
    # Hammer
    if (min(o2,c2v)-l2) > body2*1.5 and body2/rng2 < 0.5: return True
    # Bullish Engulfing
    o1,c1v = c1.get("open",0), c1.get("close",0)
    body1 = abs(c1v-o1)
    return (c1v < o1) and (c2v > o2) and (body2 >= body1*0.6) and (c2v > o1)


def _is_bearish_reversal(c1, c2):
    o2,c2v = c2.get("open",0), c2.get("close",0)
    h2,l2  = c2.get("high",0), c2.get("low",0)
    body2 = abs(c2v-o2); rng2 = h2-l2
    if rng2 < 0.05: return False
    # Shooting Star
    if (h2-max(o2,c2v)) > body2*1.5 and body2/rng2 < 0.5: return True
    # Bearish Engulfing
    o1,c1v = c1.get("open",0), c1.get("close",0)
    body1 = abs(c1v-o1)
    return (c1v > o1) and (c2v < o2) and (body2 >= body1*0.6) and (c2v < o1)


# ─── Scoring System ──────────────────────────────────────────────────────────

def calculate_score(m15_candles, asian, current_price):
    """
    คำนวณ confirmation score (max 8):
    +1 Asian range valid (size สมเหตุสมผล)
    +1 In London/NY session
    +2 Sweep occurred
    +2 Reversed back into range
    +1 Reversal candle pattern
    +1 RR >= 1.5
    """
    score = 0
    breakdown = []
    direction = None
    sweep_extreme = None

    # ── 1. Asian range valid (size 30-500 pips) ──
    if asian.detected and 30 <= asian.size_pips <= 500:
        score += 1
        breakdown.append("RangeOK(+1)")

    # ── 2. London/NY session ──
    if asian.is_london_session:
        score += 1
        breakdown.append("Session(+1)")

    if not asian.detected or not asian.is_london_session:
        return score, breakdown, None, None

    # ── 3. Sweep detection ──
    recent = m15_candles[-SWEEP_LOOKBACK:]
    last_close = m15_candles[-1].get("close", 0)

    high_ext = max((c.get("high", 0) for c in recent), default=0)
    low_ext  = min((c.get("low", 0) for c in recent if c.get("low", 0) > 0), default=99999)

    sweep_high_pips = (high_ext - asian.high) / PIP_SIZE
    sweep_low_pips  = (asian.low - low_ext) / PIP_SIZE

    if MIN_SWEEP_PIPS <= sweep_high_pips <= MAX_SWEEP_PIPS:
        score += 2
        breakdown.append(f"HighSweep+{sweep_high_pips:.0f}p(+2)")
        direction = "SELL"
        sweep_extreme = high_ext
        # Reversed back?
        if last_close < asian.high:
            score += 2
            breakdown.append("Reversed(+2)")

    elif MIN_SWEEP_PIPS <= sweep_low_pips <= MAX_SWEEP_PIPS:
        score += 2
        breakdown.append(f"LowSweep-{sweep_low_pips:.0f}p(+2)")
        direction = "BUY"
        sweep_extreme = low_ext
        if last_close > asian.low:
            score += 2
            breakdown.append("Reversed(+2)")

    if direction is None:
        return score, breakdown, None, None

    # ── 4. Reversal pattern on M15 ──
    if len(m15_candles) >= 2:
        last = m15_candles[-1]
        prev = m15_candles[-2]
        if direction == "BUY" and _is_bullish_reversal(prev, last):
            score += 1
            breakdown.append("BullPattern(+1)")
        elif direction == "SELL" and _is_bearish_reversal(prev, last):
            score += 1
            breakdown.append("BearPattern(+1)")

    return score, breakdown, direction, sweep_extreme


# ─── Entry Calculation ───────────────────────────────────────────────────────

def calc_entry(m15_candles, asian, direction, sweep_extreme, score, breakdown):
    last_close = m15_candles[-1].get("close", 0)
    entry = last_close

    if direction == "SELL":
        sl = sweep_extreme + (10 * PIP_SIZE)
        tp = asian.low
        sl_pips = (sl - entry) / PIP_SIZE
    else:
        sl = sweep_extreme - (10 * PIP_SIZE)
        tp = asian.high
        sl_pips = (entry - sl) / PIP_SIZE

    if sl_pips < MIN_SL_PIPS or sl_pips > MAX_SL_PIPS:
        return M5Signal("WAIT","Sweep",None,None,None,round(sl_pips,1),None,True,
                        f"SL {sl_pips:.0f}p out of range",
                        score=score, score_breakdown=" ".join(breakdown))

    rr = abs(tp - entry) / abs(entry - sl) if abs(entry - sl) > 0 else 0

    # +1 score ถ้า RR >= 1.5
    if rr >= MIN_RR:
        score += 1
        breakdown.append(f"RR{rr:.1f}(+1)")

    if rr < MIN_RR:
        return M5Signal("WAIT","Sweep",None,None,None,round(sl_pips,1),round(rr,2),True,
                        f"RR {rr:.2f} < {MIN_RR}",
                        score=score, score_breakdown=" ".join(breakdown))

    # ── ตัดสินใจตาม score ──
    if score >= SCORE_HIGH:
        signal = direction
        opp_label = "High"
    elif score >= SCORE_MEDIUM:
        signal = direction
        opp_label = "Medium"
    else:
        return M5Signal("WAIT","Sweep",None,None,None,round(sl_pips,1),round(rr,2),True,
                        f"Score {score} < {SCORE_MEDIUM}",
                        score=score, score_breakdown=" ".join(breakdown))

    return M5Signal(
        signal=signal, pattern=f"AsianSweep_{opp_label}",
        entry=round(entry, 2), sl=round(sl, 2), tp=round(tp, 2),
        sl_pips=round(sl_pips, 1), rr=round(rr, 2), is_with_trend=True,
        reason=f"Score {score}/8 [{' '.join(breakdown)}] | RR 1:{rr:.1f}",
        score=score, score_breakdown=" ".join(breakdown)
    )


# ─── Compatibility ───────────────────────────────────────────────────────────

class _BiasCompat:
    def __init__(self, asian, direction):
        self.direction = "Bullish" if direction == "BUY" else ("Bearish" if direction == "SELL" else "Neutral")
        self.structure = "Range"
        self.confidence = "Medium"
        self.reason = asian.reason if asian.detected else "No range"
        self.last_bos = None
        self.choch = None
        self.key_support = asian.low if asian.detected else None
        self.key_resistance = asian.high if asian.detected else None


# ─── Master Strategy ─────────────────────────────────────────────────────────

def run_strategy(h4_candles, h1_candles, m15_candles, current_price):
    asian = calc_asian_range(m15_candles)
    score, breakdown, direction, sweep_extreme = calculate_score(m15_candles, asian, current_price)

    if direction is None or sweep_extreme is None:
        return _make_skip(asian, None, score, breakdown,
                          f"Score {score}/8 — no sweep yet")

    m5 = calc_entry(m15_candles, asian, direction, sweep_extreme, score, breakdown)

    if m5.signal == "WAIT":
        return {
            "opportunity": "Medium" if m5.score >= SCORE_MEDIUM else "Low",
            "direction":   "WAIT",
            "h1_bias":     _BiasCompat(asian, direction),
            "m15_zone":    asian,
            "m5_signal":   m5,
            "reason":      f"Score {m5.score}/8 — {m5.reason}"
        }

    opp = "High" if m5.score >= SCORE_HIGH else "Medium"
    return {
        "opportunity": opp,
        "direction":   m5.signal,
        "h1_bias":     _BiasCompat(asian, direction),
        "m15_zone":    asian,
        "m5_signal":   m5,
        "reason":      f"Score {m5.score}/8 [{m5.score_breakdown}]"
    }


def _make_skip(asian, _sweep_unused, score, breakdown, reason):
    return {
        "opportunity": "Skip",
        "direction":   "WAIT",
        "h1_bias":     _BiasCompat(asian, None),
        "m15_zone":    asian,
        "m5_signal":   M5Signal("WAIT","None",None,None,None,None,None,False,reason,
                                score=score, score_breakdown=" ".join(breakdown)),
        "reason":      reason
    }
